# Postgres credentials — used directly by docker-compose.yml (postgres service,
# and to build the api container's internal DATABASE_URL against host "postgres").
POSTGRES_USER=user_api
POSTGRES_PASSWORD=changeme
POSTGRES_DB=user_api

# PostgreSQL connection string (async driver) — for running the app on the HOST
# (task dev:local / migration:up), against the port docker-compose.yml publishes
# on 127.0.0.1. Must match POSTGRES_USER/PASSWORD/DB above. Not used inside the
# api container when running via `task deploy:local` (docker-compose.yml builds
# its own DATABASE_URL there, pointing at "postgres" instead of "localhost").
DATABASE_URL=postgresql+asyncpg://user_api:changeme@localhost:5432/user_api

# Comma-separated SHA-256 hashes of valid API keys (X-API-Key header).
# Generate a key + its hash with:
#   python -c "import secrets,hashlib; k=secrets.token_urlsafe(32); print(k, hashlib.sha256(k.encode()).hexdigest())"
# Give the raw key (k) to the client, keep only the hash here.
API_KEY_HASHES=changeme_hash_1,changeme_hash_2

# Sliding-window rate limit for POST /auth/register, per IP: "<max requests>/<window seconds>s".
# In-memory, single-instance only (ADR-005) — move to a shared store (Redis) if scaling horizontally.
AUTH_REGISTER_RATE_LIMIT=10/60s

# NOTE: email verification (POST /auth/register, /auth/confirm, /auth/register/resend) uses
# ConsoleEmailSender in this version — it logs the confirmation link, it does NOT send real email
# (ADR-003). Do not deploy to public production until a real EmailSender adapter is implemented.
